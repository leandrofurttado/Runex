{
  "expo": {
    "name": "Runex",
    "slug": "runex",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "runex",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/adaptive-icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#00E373"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.runex.app",
      "icon": "./assets/adaptive-icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Runex precisa da sua localização para rastrear suas corridas.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Runex precisa da sua localização para rastrear suas corridas em segundo plano."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00E373"
      },
      "package": "com.runex.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Runex precisa da sua localização para rastrear suas corridas."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": ""
        }
      ],
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
